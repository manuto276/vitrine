<Page
    x:Class="Vitrine.Engine.Panel.Pages.AboutPage"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <StackPanel Margin="36,24,36,24">

        <TextBlock Text="About" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24" />

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Vitrine" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="Desktop widget engine for Windows"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                               Margin="0,2,0,0" />
                </StackPanel>
            </ui:CardControl.Header>
            <TextBlock x:Name="VersionText" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <TextBlock Text="License" FontWeight="SemiBold" />
            </ui:CardControl.Header>
            <TextBlock Text="MIT" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Support the project" FontWeight="SemiBold" />
                    <TextBlock Text="If you find Vitrine useful, consider making a donation"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                               Margin="0,2,0,0" />
                </StackPanel>
            </ui:CardControl.Header>
            <ui:Button Appearance="Primary" Click="OnDonateClick">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Heart24" Margin="0,0,8,0" />
                    <TextBlock Text="Donate with PayPal" />
                </StackPanel>
            </ui:Button>
        </ui:CardControl>

    </StackPanel>
</Page>
