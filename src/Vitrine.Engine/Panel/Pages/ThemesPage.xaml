<UserControl
    x:Class="Vitrine.Engine.Panel.Pages.ThemesPage"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <StackPanel Margin="36,16,36,0" MaxWidth="700" HorizontalAlignment="Left">

        <TextBlock Text="Themes" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Select a theme to apply. Themes are loaded from %APPDATA%\Vitrine\themes\."
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                   Margin="0,0,0,20" />

        <StackPanel x:Name="ThemeList" />

    </StackPanel>
</UserControl>
