<UserControl
    x:Class="Vitrine.Engine.Panel.Pages.SettingsPage"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <StackPanel Margin="36,16,36,0" MaxWidth="700" HorizontalAlignment="Left">

        <TextBlock Text="Theme Settings" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock x:Name="SubtitleText"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                   Margin="0,0,0,20" />

        <StackPanel x:Name="SettingsPanel" />

        <TextBlock x:Name="EmptyText" Text="This theme has no configurable settings."
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Visibility="Collapsed" Margin="0,8,0,0" />

        <StackPanel x:Name="ButtonBar" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <ui:Button Content="Reset Defaults" Appearance="Secondary" Click="OnResetClick" Margin="0,0,8,0" />
            <ui:Button x:Name="SaveButton" Content="Save &amp; Apply" Appearance="Primary" Click="OnSaveClick" IsEnabled="False" />
        </StackPanel>

    </StackPanel>
</UserControl>
