<Page
    x:Class="Vitrine.Engine.Panel.Pages.HomePage"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <StackPanel Margin="36,24,36,24">

        <TextBlock Text="Home" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24" />

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Active Theme" FontWeight="SemiBold" />
                    <TextBlock x:Name="ActiveThemeText" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal">
                <ui:Button Content="Reload" Appearance="Secondary" Click="OnReloadClick" Margin="0,0,8,0" />
                <ui:Button Content="Change Theme" Appearance="Primary" Click="OnChangeThemeClick" />
            </StackPanel>
        </ui:CardControl>

        <TextBlock Text="Quick Actions" FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,24,0,8" />

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Reload Theme" FontWeight="SemiBold" />
                    <TextBlock Text="Re-read theme files from disk and refresh the display"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ui:Button Content="Reload" Appearance="Secondary" Click="OnReloadClick" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Theme Settings" FontWeight="SemiBold" />
                    <TextBlock Text="Customize the active theme's appearance and behavior"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ui:Button Content="Open" Appearance="Secondary" Click="OnSettingsClick" />
        </ui:CardControl>

    </StackPanel>
</Page>
