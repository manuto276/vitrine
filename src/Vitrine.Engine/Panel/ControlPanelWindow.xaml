<ui:FluentWindow
    x:Class="Vitrine.Engine.Panel.ControlPanelWindow"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Vitrine"
    Width="960" Height="640"
    MinWidth="720" MinHeight="480"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vitrine" ShowMaximize="True" ShowMinimize="True" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation sidebar -->
            <Border Grid.Column="0" BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                <StackPanel Margin="8,12,8,8">
                    <ListBox x:Name="NavList" Background="Transparent" BorderThickness="0"
                             SelectionChanged="OnNavChanged"
                             Padding="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="12,8" />
                                <Setter Property="Margin" Value="0,1" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBoxItem Tag="home" IsSelected="True">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Home24" Margin="0,0,12,0" />
                                <TextBlock Text="Home" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="themes">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Color24" Margin="0,0,12,0" />
                                <TextBlock Text="Themes" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="about">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Info24" Margin="0,0,12,0" />
                                <TextBlock Text="About" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <ContentPresenter x:Name="PageContent" Margin="0,0,0,24" />
            </ScrollViewer>
        </Grid>
    </Grid>

</ui:FluentWindow>
