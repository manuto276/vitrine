<ui:FluentWindow
    x:Class="Vitrine.Engine.Panel.ControlPanelWindow"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Vitrine"
    Width="960" Height="640"
    MinWidth="720" MinHeight="480"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top" Title="Vitrine" ShowMaximize="True" ShowMinimize="True" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation sidebar -->
            <ListBox
                x:Name="NavList"
                Grid.Column="0"
                Background="Transparent"
                BorderThickness="0"
                Margin="8,8,4,8"
                SelectionChanged="OnNavChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Padding" Value="12,10" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBoxItem Tag="home">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Home24" FontSize="16" Margin="0,0,14,0" />
                        <TextBlock Text="Home" VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="themes">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Color24" FontSize="16" Margin="0,0,14,0" />
                        <TextBlock Text="Themes" VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="about">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Info24" FontSize="16" Margin="0,0,14,0" />
                        <TextBlock Text="About" VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <!-- Content area — no background, inherits Mica from window -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ContentPresenter x:Name="PageContent" />
            </ScrollViewer>
        </Grid>
    </DockPanel>

</ui:FluentWindow>
