<ui:FluentWindow
    x:Class="Vitrine.Engine.Panel.ControlPanelWindow"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Vitrine"
    Width="960" Height="640"
    MinWidth="720" MinHeight="480"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top" Title="Vitrine" ShowMaximize="True" ShowMinimize="True" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation sidebar -->
            <ui:ListView
                x:Name="NavList"
                Grid.Column="0"
                Margin="4,8,4,8"
                SelectionChanged="OnNavChanged">
                <ui:ListView.ItemContainerStyle>
                    <Style TargetType="ui:ListViewItem">
                        <Setter Property="MinHeight" Value="36" />
                        <Setter Property="Padding" Value="12,8" />
                        <Setter Property="Margin" Value="0,2" />
                    </Style>
                </ui:ListView.ItemContainerStyle>
                <ui:ListViewItem Tag="home">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Home24" Margin="0,0,12,0" />
                        <TextBlock Text="Home" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:ListViewItem>
                <ui:ListViewItem Tag="themes">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Color24" Margin="0,0,12,0" />
                        <TextBlock Text="Themes" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:ListViewItem>
                <ui:ListViewItem Tag="about">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Info24" Margin="0,0,12,0" />
                        <TextBlock Text="About" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:ListViewItem>
            </ui:ListView>

            <!-- Content area — no background, inherits Mica from window -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ContentPresenter x:Name="PageContent" />
            </ScrollViewer>
        </Grid>
    </DockPanel>

</ui:FluentWindow>
