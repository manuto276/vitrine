<ui:FluentWindow
    x:Class="Vitrine.Engine.Panel.ControlPanelWindow"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Vitrine"
    Width="960" Height="640"
    MinWidth="720" MinHeight="480"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vitrine" ShowMaximize="True" ShowMinimize="True" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar: use a NavigationView in LeftMinimal-like mode -->
            <ui:NavigationView
                x:Name="NavView"
                Grid.Column="0"
                PaneDisplayMode="Left"
                IsBackButtonVisible="Collapsed"
                IsPaneToggleVisible="False"
                OpenPaneLength="200"
                SelectionChanged="OnNavChanged" />

            <!-- Content -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <ContentPresenter x:Name="PageContent" Margin="0,0,0,24" />
            </ScrollViewer>
        </Grid>
    </Grid>

</ui:FluentWindow>
